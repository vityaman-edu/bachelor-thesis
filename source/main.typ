    {"parent":"TYPE","rule":"BIGINT","sum":7101},
    {"parent":"KEYWORD","rule":"UNION","sum":65064443},
    {"parent":"MODULE_FUNC","rule":"Compress::BZip2","sum":2},
    {"parent":"MODULE","rule":"re2","sum":3094},
    {"parent":"READ_HINT","rule":"COLUMNS","sum":826110},
